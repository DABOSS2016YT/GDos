{
  "name": "gdos",
  "version": "1.0.0",
  "description": "G-Dos — modern spreadsheet",
  "main": "main.js",

  "author": "Nezili",
  "license": "GPL-3.0",

  "repository": {
    "type": "git",
    "url": "https://github.com/nezili/gdos"
  },

  "scripts": {
    "start": "electron .",
    "windows": "electron-builder --win --publish never",
    "mac": "electron-builder --mac --publish never",
    "linux": "electron-builder --linux --publish never",
    "ubuntu": "electron-builder --linux deb --publish never",
    "debian": "electron-builder --linux deb --publish never",
    "all": "electron-builder --win --linux --publish never",
    "build:ui": "node -e \"const fs=require('fs');const b64=Buffer.from(fs.readFileSync('ui.html')).toString('base64');fs.writeFileSync('ui-b64.js','module.exports=\\''+b64+'\\';\\n');\""
  },

  "keywords": [
    "spreadsheet",
    "electron",
    "gdos"
  ],

  "dependencies": {
    "sql.js": "^1.12.0",
    "mongodb": "^6.5.0",
    "mssql": "^12.2.0",
    "mysql2": "^3.9.7",
    "pg": "^8.11.5",
    "redis": "^4.6.13",
    "exceljs": "^4.4.0"
  },

  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  },

  "build": {
    "appId": "uk.nezili.gdos",
    "productName": "G-Dos",
    "copyright": "Copyright © 2026 Nezili",
    "asar": true,

    "asarUnpack": [
      "**/*.node"
    ],

    "files": [
      "main.js",
      "ui-b64.js",
      "splash.html",
      "package.json",
      "gdos.pubkey",
      "LICENSE"
    ],

    "extraResources": [
      {
        "from": "gdos.pubkey",
        "to": "gdos.pubkey"
      }
    ],

    "directories": {
      "output": "dist",
      "buildResources": "build"
    },

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },

    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "G-Dos",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico"
    },

    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "icon.icns",
      "category": "public.app-category.productivity"
    },

    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png",
      "category": "Office"
    },

    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1"
      ]
    }
  },

  "engines": {
    "node": ">=20.0.0"
  },

  "overrides": {
    "glob": "^11.0.0",
    "rimraf": "^5.0.0"
  }
}
